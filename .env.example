# رقم واتساب الحقيقي (مع رمز الدولة) — يستخدم في footer + floating button + contact page
# مثال: +966555123456
NEXT_PUBLIC_WHATSAPP_NUMBER=

# مفتاح Resend لإرسال رسائل النموذج بالبريد
# اذهب لـ resend.com وأنشئ حساب، ثم API Keys → New
RESEND_API_KEY=

# البريد الذي يستقبل طلبات النموذج (اختياري، الافتراضي noureddin@sura.studio)
CONTACT_TO_EMAIL=noureddin@sura.studio
